NODE_ENV=development
PORT=8080
# Comma-separated frontend origins. Do not include a trailing slash.
CLIENT_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app

LLM_PROVIDER=nvidia_nim
EMBEDDING_PROVIDER=nvidia_nim
EMBEDDING_DIMENSIONS=1536

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=meeting-recordings
MAX_UPLOAD_SIZE_MB=50

DEEPGRAM_API_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_CHAT_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_NIM_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
